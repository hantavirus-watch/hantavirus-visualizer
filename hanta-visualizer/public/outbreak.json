import React, { useEffect, useState } from 'react';
import { MapContainer, TileLayer, Marker, Popup } from 'react-leaflet';
import { AlertTriangle, List, Map as MapIcon } from 'lucide-react';
import 'leaflet/dist/leaflet.css';
import L from 'leaflet';

// Fix icone Leaflet
delete L.Icon.Default.prototype._getIconUrl;
L.Icon.Default.mergeOptions({
  iconRetinaUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon-2x.png',
  iconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon.png',
  shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
});

function App() {
  const [allData, setAllData] = useState([]);
  const [mapData, setMapData] = useState([]);

  useEffect(() => {
    fetch('./outbreaks.json')
      .then(res => res.json())
      .then(data => {
        setAllData(data);
        setMapData(data.filter(o => o.coordinates));
      })
      .catch(err => console.error("Data error:", err));
  }, []);

  return (
    <div style={{ height: '100vh', display: 'flex', flexDirection: 'column', fontFamily: 'sans-serif' }}>
      {/* Header Emergenza */}
      <header style={{ background: '#b91c1c', color: 'white', padding: '1rem', display: 'flex', justifyContent: 'space-between', alignItems: 'center', zIndex: 1000 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: '10px' }}>
          <AlertTriangle size={24} />
          <h1 style={{ margin: 0, fontSize: '1.2rem', fontWeight: 'bold' }}>HANTAWATCH GLOBAL LIVE</h1>
        </div>
        <div style={{ fontSize: '0.8rem', opacity: 0.9 }}>
          Tracking {allData.length} alerts | {mapData.length} geolocated
        </div>
      </header>

      <div style={{ display: 'flex', flexGrow: 1, overflow: 'hidden' }}>
        {/* Sidebar News */}
        <aside style={{ width: '350px', overflowY: 'auto', borderRight: '1px solid #ddd', background: '#f8fafc' }}>
          <div style={{ padding: '15px', borderBottom: '1px solid #ddd', background: '#fff', position: 'sticky', top: 0 }}>
            <h2 style={{ fontSize: '0.9rem', display: 'flex', alignItems: 'center', gap: '5px' }}><List size={16}/> Latest Alerts</h2>
          </div>
          {allData.map((item, i) => (
            <div key={i} style={{ padding: '15px', borderBottom: '1px solid #eee', fontSize: '0.85rem', background: item.coordinates ? '#fff' : '#f1f5f9' }}>
              <div style={{ fontWeight: 'bold', marginBottom: '5px' }}>{item.title}</div>
              <div style={{ color: '#64748b', fontSize: '0.75rem', marginBottom: '8px' }}>{item.source} • {new Date(item.published).toLocaleDateString()}</div>
              <a href={item.link} target="_blank" rel="noreferrer" style={{ color: '#b91c1c', textDecoration: 'none', fontWeight: '600' }}>View Report →</a>
            </div>
          ))}
        </aside>

        {/* Mappa */}
        <main style={{ flexGrow: 1, position: 'relative' }}>
          <MapContainer center={[20, 0]} zoom={2} style={{ height: '100%', width: '100%' }}>
            <TileLayer url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png" />
            {mapData.map((marker, idx) => (
              <Marker key={idx} position={marker.coordinates}>
                <Popup>
                  <strong>{marker.title}</strong><br/>
                  <a href={marker.link} target="_blank" rel="noreferrer">Details</a>
                </Popup>
              </Marker>
            ))}
          </MapContainer>
        </main>
      </div>
    </div>
  );
}

export default App;